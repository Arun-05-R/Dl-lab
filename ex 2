import tensorflow as tf
import numpy as np
import pandas as pd
import pathlib
import os

# Tensor dataset
t1 = tf.constant([[1,2,3],[4,5,6],[7,8,9]], dtype=tf.float32)
ds = tf.data.Dataset.from_tensor_slices(t1)
for i in ds:
    print(i)

# Image dataset
train, _ = tf.keras.datasets.fashion_mnist.load_data()
images, labels = train
images = images / 255.0

dataset = tf.data.Dataset.from_tensor_slices((images, labels))
dataset = dataset.shuffle(1000).batch(32)

for img, lab in dataset.take(1):
    print(img.shape, lab.shape)

# CSV dataset
titanic_file = tf.keras.utils.get_file(
"train.csv",
"https://storage.googleapis.com/tf-datasets/titanic/train.csv"
)

df = pd.read_csv(titanic_file)
csv_ds = tf.data.Dataset.from_tensor_slices(dict(df))

for data in csv_ds.take(1):
    print(data)

# File dataset
flowers_root = tf.keras.utils.get_file(
'flower_photos',
'https://storage.googleapis.com/download.tensorflow.org/example_images/flower_photos.tgz',
untar=True
)

flowers_root = pathlib.Path(flowers_root)
file_ds = tf.data.Dataset.list_files(str(flowers_root/'*/*'))

def process_path(file_path):
    label = tf.strings.split(file_path, os.sep)[-2]
    return tf.io.read_file(file_path), label

file_ds = file_ds.map(process_path)

for img, label in file_ds.take(1):
    print(label)

# Batching
ds = tf.data.Dataset.range(10)
ds = ds.batch(4)
for i in ds:
    print(i)

# Model training
model = tf.keras.Sequential([
tf.keras.layers.Flatten(),
tf.keras.layers.Dense(10)
])

model.compile(optimizer='adam',
loss=tf.keras.losses.SparseCategoricalCrossentropy(from_logits=True),
metrics=['accuracy'])

model.fit(dataset, epochs=1)
